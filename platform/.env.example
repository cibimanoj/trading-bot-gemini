# ==========================================
# TRADING PLATFORM - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to `.env` and configure it.
# The microservices read variables dynamically from process.env.

# --- Global / Security ---
# Be sure to change this secret in a real environment.
JWT_SECRET=dev-insecure-change-me
BCRYPT_ROUNDS=10

# --- Connections ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trading_assistant
KAFKA_BROKERS=localhost:9092
REDIS_URL=redis://localhost:6379

# --- API Gateway ---
PORT=3000
USER_SERVICE_URL=http://127.0.0.1:3002

# --- Third-Party Integrations ---
# Replace the base URL and access token with the actual provider information
GROWW_API_BASE_URL=https://api.groww.in/v1
GROWW_ACCESS_TOKEN=your-groww-api-token-here

# --- Market Data & Options Intel ---
# SYMBOLS must be comma-separated without spaces
SYMBOLS=NIFTY,BANKNIFTY
POLL_MS=2000

# --- Risk Engine ---
# Equity and percentages are calculated as floats
ACCOUNT_EQUITY=100000
RISK_PCT=0.015
MIN_RR=1.5
DAILY_LOSS_LIMIT_PCT=0.03
