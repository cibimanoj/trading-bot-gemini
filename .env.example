KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=current_access_token_here

TELEGRAM_BOT_TOKEN=your_bot_token_here
# Comma-separated chat ids (private and/or group) for alerts + bot commands
TELEGRAM_CHAT_ID=your_chat_id_here

# Initial capital
INITIAL_CAPITAL=50000

# Optional risk free rate for black-scholes
RISK_FREE_RATE=0.065

# Exchange lot sizes (fallback when instrument master has no lot_size)
# NIFTY_LOT_SIZE=75
# BANKNIFTY_LOT_SIZE=15

# DB retention (pruned once per IST day during market scheduler)
# DB_PRUNE_MARKET_SNAPSHOT_DAYS=45
# DB_PRUNE_SIGNALS_DAYS=365
# DB_PORTFOLIO_MAX_ROWS=3000
# DB_PATH=sqlite.db

# Trend long options: skip BUY_CE/BUY_PE when IV percentile rank is above this (aligns with Scorer)
# MAX_IV_PERCENTILE_FOR_DIRECTIONAL_LONG=35
